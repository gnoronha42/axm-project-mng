{
  "name": "axm-project-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:api": "npm run dev --prefix server",
    "dev:all": "concurrently -k -n \"web,api\" -c \"blue,green\" \"npm run dev:web\" \"npm run dev:api\"",
    "db:up": "docker-compose up -d postgres",
    "db:setup": "npm run db:setup --prefix server",
    "build": "tsc -b && vite build",
    "build:all": "npm run build && npm run build --prefix server",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@tanstack/react-query": "^5.96.2",
    "antd": "^6.3.5",
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
